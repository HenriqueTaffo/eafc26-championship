{
  "name": "eafc26-championship",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "check": "npm run check:js",
    "check:js": "for file in js/*.js; do node --check \"$file\"; done",
    "sync:ea-ratings": "node scripts/import-ea-ratings.js",
    "sync:ea-ratings:dry": "node scripts/import-ea-ratings.js --dry-run",
    "sync:futbin-ratings": "node scripts/import-futbin-ratings.js",
    "sync:futbin-ratings:dry": "node scripts/import-futbin-ratings.js --dry-run",
    "sync:fifaratings-market": "node scripts/import-fifaratings-market.js",
    "sync:fifaratings-market:dry": "node scripts/import-fifaratings-market.js --dry-run",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint": "eslint js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
