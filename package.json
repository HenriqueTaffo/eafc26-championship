{
  "name": "eafc26-championship",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/copy-static-assets.cjs",
    "preview": "vite preview --host 127.0.0.1",
    "check": "npm run check:js && npm run build",
    "check:js": "node scripts/check-js.cjs",
    "sync:ea-ratings": "node scripts/import-ea-ratings.js",
    "sync:ea-ratings:dry": "node scripts/import-ea-ratings.js --dry-run",
    "sync:futbin-ratings": "node scripts/import-futbin-ratings.js",
    "sync:futbin-ratings:dry": "node scripts/import-futbin-ratings.js --dry-run",
    "sync:fifaratings-market": "node scripts/import-fifaratings-market.js",
    "sync:fifaratings-market:dry": "node scripts/import-fifaratings-market.js --dry-run",
    "sync:argentina-market": "node scripts/generate-argentina-market-fallback.js",
    "sync:transfermarkt-values": "node scripts/sync-transfermarkt-market-values.js",
    "sync:transfermarkt-values:dry": "node scripts/sync-transfermarkt-market-values.js --dry-run",
    "sync:transfermarkt-values:window": "node scripts/sync-transfermarkt-market-values.js --limit=250 --delay-ms=900 --retry-count=3 --retry-delay-ms=1200",
    "sync:market-avatar-cache": "node scripts/generate-market-avatar-cache.js",
    "sync:market-avatar-cache-db": "node scripts/sync-market-avatars-from-cache.js",
    "sync:market-avatar-cache-db:dry": "node scripts/sync-market-avatars-from-cache.js --dry-run",
    "sync:market-avatars": "node scripts/backfill-player-avatars.js",
    "sync:market-avatars:dry": "node scripts/backfill-player-avatars.js --dry-run",
    "sync:capology-salaries": "node scripts/sync-capology-salaries.js --all-clubs --sql-out=supabase/.temp/capology-salary-sync.sql --json-out=supabase/.temp/capology-salary-sync.json",
    "sync:capology-salaries:dry": "node scripts/sync-capology-salaries.js --all-clubs --dry-run",
    "sync:capology-salaries:window": "node scripts/sync-capology-salaries.js --all-clubs --limit=25 --concurrency=3 --retry-count=4 --retry-delay-ms=1500 --sql-out=supabase/.temp/capology-salary-sync.sql --json-out=supabase/.temp/capology-salary-sync.json",
    "sync:precision:priority": "node scripts/sync-priority-player-data.js",
    "build:css": "vite build",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint": "eslint js src scripts/check-js.cjs vite.config.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^8.57.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^8.57.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.0.0",
    "sass": "^1.69.7",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.26",
    "@xstate/react": "^6.1.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "date-fns-tz": "^3.2.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.76.1",
    "react-is": "^19.2.6",
    "recharts": "^3.8.1",
    "rrule": "^2.8.1",
    "vite-plugin-pwa": "^1.3.0",
    "xstate": "^5.31.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HenriqueTaffo/eafc26-championship.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HenriqueTaffo/eafc26-championship/issues"
  },
  "homepage": "https://github.com/HenriqueTaffo/eafc26-championship#readme",
  "description": "",
  "volta": {
    "node": "22.22.3",
    "npm": "10.9.8"
  }
}
